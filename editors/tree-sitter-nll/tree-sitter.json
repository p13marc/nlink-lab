    "license": "MIT",
    "description": "Tree-sitter grammar for NLL (nlink-lab Language)",
    "authors": [
      { "name": "nlink-lab contributors" }
    ],
    "links": {
      "repository": "https://github.com/p13marc/nlink-lab"
    }
  },
