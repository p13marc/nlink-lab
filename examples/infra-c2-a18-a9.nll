# Infrastructure: 1x C2, 2x A18, 2x A9 drone control network.
#
# C2 (Command & Control): DC1, DC2, DCS, FIREWALL
# A18 (Remote drone):     CC, CU, RED (≈DCS), BLACK (≈FIREWALL)
# A9  (Remote drone):     CC (≈BLACK+RED+CC), CU
#
# Data path:  DC → DCS → FIREWALL → [modem] → BLACK → RED → CC/CU
#
# Addressing:
#   Internal: 10.ASSET_ID.SUBNET.HOST/24
#   DCS routing: 144.0.LINK_TYPE.DEST_ASSET_ID/32 via FIREWALL
#   Modem links: 172.100.LINK_ID.ASSET_ID/24
#   FIREWALL DNATs 144.0.Y.Z → 172.100.LINK_ID.Z
#
# Link types: 1=FO, 2=SAT, 3=radio, 4=wifi
# Asset IDs:  2=C2, 18=A18a, 19=A18b, 9=A9a, 10=A9b
#
# Modem links:
#   C2 ↔ A18a/A18b: FO, SAT, radio (3 links each)
#   C2 ↔ A9a/A9b:   FO, wifi (2 links each)

lab "infra" {
  description "C2 + 2xA18 + 2xA9 drone control infrastructure"
  dns hosts
}

profile router { forward ipv4 }

# Link type profiles (uncomment impairments to simulate)
defaults fiber { delay 1ms }
# defaults satellite { delay 300ms jitter 50ms }
# defaults radio { delay 15ms jitter 10ms loss 2% }
# defaults wifi-link { delay 3ms jitter 2ms loss 0.5% }

# ═══════════════════════════════════════════════════════════
# Asset C2 — Command & Control
# ═══════════════════════════════════════════════════════════

node dc1 { route default via 10.2.1.3 }
node dc2 { route default via 10.2.1.3 }

# DCS: Connectivity Solution — 144.0.LINK_TYPE.DEST via FIREWALL
node dcs : router {
  # A18a (asset 18): FO, SAT, radio
  route [144.0.1.18/32, 144.0.2.18/32, 144.0.3.18/32] via 10.2.2.2
  # A18b (asset 19): FO, SAT, radio
  route [144.0.1.19/32, 144.0.2.19/32, 144.0.3.19/32] via 10.2.2.2
  # A9a (asset 9): FO, wifi
  route [144.0.1.9/32, 144.0.4.9/32] via 10.2.2.2
  # A9b (asset 10): FO, wifi
  route [144.0.1.10/32, 144.0.4.10/32] via 10.2.2.2
}

# FIREWALL: NAT 144.0.Y.Z → modem 172.100.LINK.Z
node c2-fw : router {
  route 10.2.1.0/24 via 10.2.2.1

  nat {
    masquerade src 10.2.0.0/16
    # A18a (asset 18)
    dnat dst 144.0.1.18/32 to 172.100.1.18
    dnat dst 144.0.2.18/32 to 172.100.2.18
    dnat dst 144.0.3.18/32 to 172.100.3.18
    # A18b (asset 19)
    dnat dst 144.0.1.19/32 to 172.100.4.19
    dnat dst 144.0.2.19/32 to 172.100.5.19
    dnat dst 144.0.3.19/32 to 172.100.6.19
    # A9a (asset 9)
    dnat dst 144.0.1.9/32 to 172.100.7.9
    dnat dst 144.0.4.9/32 to 172.100.8.9
    # A9b (asset 10)
    dnat dst 144.0.1.10/32 to 172.100.9.10
    dnat dst 144.0.4.10/32 to 172.100.10.10
  }
}

# ═══════════════════════════════════════════════════════════
# Internal links — C2
# ═══════════════════════════════════════════════════════════

# DC shared LAN (DC1 .1, DC2 .2, DCS .3)
network c2-dc {
  members [dc1:eth0, dc2:eth0, dcs:eth0]
  subnet 10.2.1.0/24
}

# DCS ↔ FIREWALL
link dcs:eth1 -- c2-fw:eth0 { 10.2.2.1/24 -- 10.2.2.2/24 }

# ═══════════════════════════════════════════════════════════
# Asset A18a (drone, asset ID 18)
# ═══════════════════════════════════════════════════════════

site a18a {
  node cc { route default via 10.18.1.3 }
  node cu { route default via 10.18.1.3 }

  node red : router {
    route 172.100.0.0/16 via 10.18.2.2
  }

  node black : router {
    route 10.18.1.0/24 via 10.18.2.1
    nat { masquerade src 10.18.0.0/16 }
  }

  link red:eth1 -- black:eth0 { 10.18.2.1/24 -- 10.18.2.2/24 }
}

network a18a-lan {
  members [a18a-cc:eth0, a18a-cu:eth0, a18a-red:eth0]
  subnet 10.18.1.0/24
}

# ═══════════════════════════════════════════════════════════
# Asset A18b (drone, asset ID 19)
# ═══════════════════════════════════════════════════════════

site a18b {
  node cc { route default via 10.19.1.3 }
  node cu { route default via 10.19.1.3 }

  node red : router {
    route 172.100.0.0/16 via 10.19.2.2
  }

  node black : router {
    route 10.19.1.0/24 via 10.19.2.1
    nat { masquerade src 10.19.0.0/16 }
  }

  link red:eth1 -- black:eth0 { 10.19.2.1/24 -- 10.19.2.2/24 }
}

network a18b-lan {
  members [a18b-cc:eth0, a18b-cu:eth0, a18b-red:eth0]
  subnet 10.19.1.0/24
}

# ═══════════════════════════════════════════════════════════
# Asset A9a (drone, asset ID 9, simplified: CC = BLACK+RED+CC)
# ═══════════════════════════════════════════════════════════

site a9a {
  node cu { route default via 10.9.1.1 }
  node cc : router
  link cc:eth0 -- cu:eth0 { 10.9.1.1/24 -- 10.9.1.2/24 }
}

# ═══════════════════════════════════════════════════════════
# Asset A9b (drone, asset ID 10, simplified)
# ═══════════════════════════════════════════════════════════

site a9b {
  node cu { route default via 10.10.1.1 }
  node cc : router
  link cc:eth0 -- cu:eth0 { 10.10.1.1/24 -- 10.10.1.2/24 }
}

# ═══════════════════════════════════════════════════════════
# Modem links (WAN)
#
# Convention: 172.100.LINK_ID.ASSET_ID/24
# LINK_ID is unique per physical link (1-10)
# ═══════════════════════════════════════════════════════════

# C2 ↔ A18a: FO, SAT, radio
link c2-fw:fo-a18a -- a18a-black:fo : fiber { 172.100.1.2/24 -- 172.100.1.18/24 }
link c2-fw:sat-a18a -- a18a-black:sat { 172.100.2.2/24 -- 172.100.2.18/24 }
link c2-fw:rad-a18a -- a18a-black:radio { 172.100.3.2/24 -- 172.100.3.18/24 }

# C2 ↔ A18b: FO, SAT, radio
link c2-fw:fo-a18b -- a18b-black:fo : fiber { 172.100.4.2/24 -- 172.100.4.19/24 }
link c2-fw:sat-a18b -- a18b-black:sat { 172.100.5.2/24 -- 172.100.5.19/24 }
link c2-fw:rad-a18b -- a18b-black:radio { 172.100.6.2/24 -- 172.100.6.19/24 }

# C2 ↔ A9a: FO, wifi
link c2-fw:fo-a9a -- a9a-cc:fo : fiber { 172.100.7.2/24 -- 172.100.7.9/24 }
link c2-fw:wifi-a9a -- a9a-cc:wifi { 172.100.8.2/24 -- 172.100.8.9/24 }

# C2 ↔ A9b: FO, wifi
link c2-fw:fo-a9b -- a9b-cc:fo : fiber { 172.100.9.2/24 -- 172.100.9.10/24 }
link c2-fw:wifi-a9b -- a9b-cc:wifi { 172.100.10.2/24 -- 172.100.10.10/24 }

# ═══════════════════════════════════════════════════════════
# Validation
# ═══════════════════════════════════════════════════════════

validate {
  # C2 internal
  reach dc1 dcs
  reach dcs c2-fw

  # A18a internal
  reach a18a-cc a18a-red
  reach a18a-red a18a-black

  # A18b internal
  reach a18b-cc a18b-red

  # A9a/A9b internal
  reach a9a-cc a9a-cu
  reach a9b-cc a9b-cu

  # WAN reachability
  reach c2-fw a18a-black
  reach c2-fw a18b-black
  reach c2-fw a9a-cc
  reach c2-fw a9b-cc
}
