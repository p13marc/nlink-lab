{
  "name": "tree-sitter-nll",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for NLL (nlink-lab Language)",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "parser", "nll", "nlink-lab"],
  "license": "MIT",
  "dependencies": {
    "node-addon-api": "^8.3.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.nll",
      "file-types": ["nll"],
      "highlights": "queries/highlights.scm",
      "injection-regex": "nll"
    }
  ]
}
