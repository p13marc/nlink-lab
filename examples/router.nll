# Router topology: one router connecting two hosts.
#
#   host1 (10.0.1.2) ──── router ──── host2 (10.0.2.2)
#                       eth0    eth1

lab "router" {
  description "Router between two subnets"
}

profile router { forward ipv4 }

node router : router
node host1 { route default via 10.0.1.1 }
node host2 { route default via 10.0.2.1 }

link router:eth0 -- host1:eth0 {
  10.0.1.1/24 -- 10.0.1.2/24
}

link router:eth1 -- host2:eth0 {
  10.0.2.1/24 -- 10.0.2.2/24
}
