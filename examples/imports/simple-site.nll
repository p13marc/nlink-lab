# Simple site template — 2 nodes (router + host).
#
# param id: site ID — determines IP addressing.
# Routes auto-generated by `routing auto` in the main topology.

lab "simple-site-template"

profile router { forward ipv4 }
param id

let lan = subnet("10.0.0.0/8", 24, ${id * 256 + 1})

node cu
node cc : router

link cc:eth0 -- cu:eth0 { host(${lan}, 1)/24 -- host(${lan}, 2)/24 }
