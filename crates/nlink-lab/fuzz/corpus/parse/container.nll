# Container topology: an Alpine container connected to a bare namespace host.
#
#   router (container)  ──── host (namespace)
#   alpine:latest          10.0.0.1    10.0.0.2

lab "container" {
  description "Container node connected to bare namespace"
}

node router image "alpine:latest" cmd "sleep infinity"
node host { route default via 10.0.0.1 }

link router:eth0 -- host:eth0 {
  10.0.0.1/24 -- 10.0.0.2/24
}
