# Infrastructure: 1x C2, 2x A18, 2x A9 drone control network.
#
# Demonstrates: subnet()/host() IP functions, for-inside-blocks,
# site grouping, NAT with for-loops, route groups, link profiles.
#
# Data path:  DC → DCS → FIREWALL → [modem] → BLACK → RED → CC/CU

lab "infra" {
  description "C2 + 2xA18 + 2xA9 drone control infrastructure"
  dns hosts
}

profile router { forward ipv4 }
defaults fiber { delay 1ms }

# ═══════════════════════════════════════════════════════════
# Asset C2 — Command & Control (computed addressing)
# ═══════════════════════════════════════════════════════════

let c2 = subnet("10.0.0.0/8", 16, 2)
let dc-lan = subnet(${c2}, 24, 1)
let dcs-fw = subnet(${c2}, 24, 2)

node dc1 { route default via host(${dc-lan}, 3) }
node dc2 { route default via host(${dc-lan}, 3) }

# DCS: routes generated with for-loops
node dcs : router {
  for asset in [18, 19] {
    for lt in [1, 2, 3] {
      route 144.0.${lt}.${asset}/32 via host(${dcs-fw}, 2)
    }
  }
  for asset in [9, 10] {
    for lt in [1, 4] {
      route 144.0.${lt}.${asset}/32 via host(${dcs-fw}, 2)
    }
  }
}

# FIREWALL: NAT rules generated with for-loops
node c2-fw : router {
  route ${dc-lan} via host(${dcs-fw}, 1)
  nat {
    masquerade src ${c2}
    for asset in [18, 19] {
      for lt in [1, 2, 3] {
        dnat dst 144.0.${lt}.${asset}/32 to host(subnet("172.100.0.0/16", 24, ${lt}), ${asset})
      }
    }
    for asset in [9, 10] {
      for lt in [1, 4] {
        dnat dst 144.0.${lt}.${asset}/32 to host(subnet("172.100.0.0/16", 24, ${lt}), ${asset})
      }
    }
  }
}

network c2-dc {
  members [dc1:eth0, dc2:eth0, dcs:eth0]
  subnet ${dc-lan}
}
link dcs:eth1 -- c2-fw:eth0 { host(${dcs-fw}, 1)/24 -- host(${dcs-fw}, 2)/24 }

# ═══════════════════════════════════════════════════════════
# A18 (drone, asset 18) — CC, CU, RED, BLACK
# ═══════════════════════════════════════════════════════════

site a18 {
  node cc { route default via 10.18.1.3 }
  node cu { route default via 10.18.1.3 }
  node red : router { route 172.100.0.0/16 via 10.18.2.2 }
  node black : router {
    route 10.18.1.0/24 via 10.18.2.1
    nat { masquerade src 10.18.0.0/16 }
  }
  network lan {
    members [cc:eth0, cu:eth0, red:eth0]
    subnet 10.18.1.0/24
  }
  link red:eth1 -- black:eth0 { 10.18.2.1/24 -- 10.18.2.2/24 }
}

# ═══════════════════════════════════════════════════════════
# A19 (drone, asset 19) — same structure, different IPs
# ═══════════════════════════════════════════════════════════

site a19 {
  node cc { route default via 10.19.1.3 }
  node cu { route default via 10.19.1.3 }
  node red : router { route 172.100.0.0/16 via 10.19.2.2 }
  node black : router {
    route 10.19.1.0/24 via 10.19.2.1
    nat { masquerade src 10.19.0.0/16 }
  }
  network lan {
    members [cc:eth0, cu:eth0, red:eth0]
    subnet 10.19.1.0/24
  }
  link red:eth1 -- black:eth0 { 10.19.2.1/24 -- 10.19.2.2/24 }
}

# ═══════════════════════════════════════════════════════════
# A9/A10 (simplified drones: CC = BLACK+RED+CC)
# ═══════════════════════════════════════════════════════════

site a9 {
  node cu { route default via 10.9.1.1 }
  node cc : router
  link cc:eth0 -- cu:eth0 { 10.9.1.1/24 -- 10.9.1.2/24 }
}

site a10 {
  node cu { route default via 10.10.1.1 }
  node cc : router
  link cc:eth0 -- cu:eth0 { 10.10.1.1/24 -- 10.10.1.2/24 }
}

# ═══════════════════════════════════════════════════════════
# Modem links (WAN)
# ═══════════════════════════════════════════════════════════

# C2 ↔ A18: FO, SAT, radio
link c2-fw:fo-a18 -- a18-black:fo : fiber { 172.100.1.2/24 -- 172.100.1.18/24 }
link c2-fw:sat-a18 -- a18-black:sat { 172.100.2.2/24 -- 172.100.2.18/24 }
link c2-fw:rad-a18 -- a18-black:radio { 172.100.3.2/24 -- 172.100.3.18/24 }

# C2 ↔ A19: FO, SAT, radio
link c2-fw:fo-a19 -- a19-black:fo : fiber { 172.100.1.2/24 -- 172.100.1.19/24 }
link c2-fw:sat-a19 -- a19-black:sat { 172.100.2.2/24 -- 172.100.2.19/24 }
link c2-fw:rad-a19 -- a19-black:radio { 172.100.3.2/24 -- 172.100.3.19/24 }

# C2 ↔ A9: FO, wifi
link c2-fw:fo-a9 -- a9-cc:fo : fiber { 172.100.1.2/24 -- 172.100.1.9/24 }
link c2-fw:wifi-a9 -- a9-cc:wifi { 172.100.4.2/24 -- 172.100.4.9/24 }

# C2 ↔ A10: FO, wifi
link c2-fw:fo-a10 -- a10-cc:fo : fiber { 172.100.1.2/24 -- 172.100.1.10/24 }
link c2-fw:wifi-a10 -- a10-cc:wifi { 172.100.4.2/24 -- 172.100.4.10/24 }

# ═══════════════════════════════════════════════════════════
# Validation
# ═══════════════════════════════════════════════════════════

validate {
  reach dc1 dcs
  reach dcs c2-fw
  reach a18-cc a18-red
  reach a19-cc a19-red
  reach a9-cc a9-cu
  reach a10-cc a10-cu
  reach c2-fw a18-black
  reach c2-fw a19-black
  reach c2-fw a9-cc
  reach c2-fw a10-cc
}
